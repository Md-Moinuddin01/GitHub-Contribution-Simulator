// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum IssueStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  CLOSED
}

enum PullRequestStatus {
  DRAFT
  OPEN
  CHANGES_REQUESTED
  APPROVED
  MERGED
  CLOSED
}

enum ReviewDecision {
  COMMENT
  REQUEST_CHANGES
  APPROVE
}

enum ActivityType {
  ISSUE_ASSIGNED
  FILE_SAVED
  COMMIT_CREATED
  PULL_REQUEST_OPENED
  REVIEW_RECEIVED
  PULL_REQUEST_MERGED
  BADGE_UNLOCKED
  CONFLICT_RESOLVED
}

model User {
  id                 String         @id @default(cuid())
  name               String?
  email              String?        @unique
  emailVerified      DateTime?
  image              String?
  username           String         @unique
  passwordHash       String?
  avatar             String?
  role               UserRole       @default(USER)
  level              Int            @default(1)
  xp                 Int            @default(0)
  contributionsCount Int            @default(0)
  currentStreak      Int            @default(0)
  longestStreak      Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  accounts           Account[]
  sessions           Session[]
  assignedIssues     Issue[]        @relation("AssignedIssues")
  pullRequests       PullRequest[]
  commits            Commit[]
  reviews            Review[]
  comments           Comment[]
  badges             UserBadge[]
  contributions      Contribution[]
  activities         Activity[]
  leaderboard        Leaderboard?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repository {
  id             String        @id @default(cuid())
  slug           String        @unique
  name           String
  description    String
  techStack      String[]
  readme         String        @db.Text
  fileStructure  Json
  fakeStars      Int           @default(0)
  fakeForks      Int           @default(0)
  difficulty     Difficulty    @default(BEGINNER)
  maintainerName String
  tags           String[]
  githubUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  issues         Issue[]
  pullRequests   PullRequest[]
  commits        Commit[]
  files          File[]
  branches       Branch[]
}

model Issue {
  id               String       @id @default(cuid())
  repositoryId     String
  assignedUserId   String?
  title            String
  description      String       @db.Text
  difficulty       Difficulty
  labels           String[]
  xpReward         Int
  status           IssueStatus  @default(OPEN)
  expectedSolution String       @db.Text
  testCases        Json
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  repository       Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  assignedUser     User?        @relation("AssignedIssues", fields: [assignedUserId], references: [id])
  pullRequests     PullRequest[]
}

model PullRequest {
  id            String            @id @default(cuid())
  number        Int
  repositoryId  String
  issueId       String?
  authorId      String
  title         String
  description   String            @db.Text
  sourceBranch  String
  targetBranch  String            @default("main")
  status        PullRequestStatus @default(DRAFT)
  checklist     Json
  changedFiles  Json
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  mergedAt      DateTime?

  repository    Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  issue         Issue?            @relation(fields: [issueId], references: [id])
  author        User              @relation(fields: [authorId], references: [id])
  commits       Commit[]
  reviews       Review[]
  comments      Comment[]

  @@unique([repositoryId, number])
}

model Commit {
  id            String       @id @default(cuid())
  hash          String       @unique
  message       String
  repositoryId  String
  pullRequestId String?
  authorId      String
  changedFiles  Json
  createdAt     DateTime     @default(now())

  repository    Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest? @relation(fields: [pullRequestId], references: [id])
  author        User         @relation(fields: [authorId], references: [id])
}

model Review {
  id            String         @id @default(cuid())
  pullRequestId String
  reviewerId    String?
  reviewerName  String
  reviewerAvatar String?
  decision      ReviewDecision
  summary       String         @db.Text
  lineComments  Json
  score         Int            @default(0)
  createdAt     DateTime       @default(now())

  pullRequest   PullRequest    @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  reviewer      User?          @relation(fields: [reviewerId], references: [id])
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  xpReward    Int         @default(0)
  createdAt   DateTime    @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Contribution {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  commits   Int      @default(0)
  issues    Int      @default(0)
  prsMerged Int      @default(0)
  reviews   Int      @default(0)
  xpEarned  Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Comment {
  id            String       @id @default(cuid())
  pullRequestId String?
  authorId      String?
  path          String?
  line          Int?
  body          String       @db.Text
  createdAt     DateTime     @default(now())

  pullRequest   PullRequest? @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  author        User?        @relation(fields: [authorId], references: [id])
}

model File {
  id           String      @id @default(cuid())
  repositoryId String
  path         String
  language     String
  content      String      @db.Text
  starter      String      @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  repository   Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, path])
}

model Branch {
  id           String      @id @default(cuid())
  repositoryId String
  name         String
  baseBranch   String?
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())

  repository   Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
}

model Activity {
  id        String       @id @default(cuid())
  userId    String?
  type      ActivityType
  message   String
  metadata  Json
  createdAt DateTime     @default(now())

  user      User?        @relation(fields: [userId], references: [id])
}

model Leaderboard {
  id          String   @id @default(cuid())
  userId      String   @unique
  rank        Int
  score       Int
  weeklyScore Int      @default(0)
  streak      Int      @default(0)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
